# Copy to .env.local — paste from Firebase Console → Project settings → Your apps → Web app
# IMPORTANT: use the Web API Key from Project settings → General (starts with AIza...)
# authDomain must be PROJECT_ID.firebaseapp.com (e.g. phynesse-wpe.firebaseapp.com)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
